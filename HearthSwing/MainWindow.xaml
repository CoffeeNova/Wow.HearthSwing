<Window
  x:Class="HearthSwing.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  Title="HearthSwing"
  Icon="pack://application:,,,/app.ico"
  Height="640"
  Width="420"
  MinHeight="580"
  MinWidth="380"
  Background="#1a1a2e"
  ResizeMode="CanResizeWithGrip"
  WindowStartupLocation="CenterScreen"
>
  <Window.Resources>
    <!-- Accent colors -->
    <SolidColorBrush x:Key="DonkyBrush" Color="#4a9eff" />
    <SolidColorBrush x:Key="TanyaBrush" Color="#e84393" />
    <SolidColorBrush x:Key="PanelBg" Color="#16213e" />
    <SolidColorBrush x:Key="CardBg" Color="#0f3460" />
    <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0" />
    <SolidColorBrush x:Key="TextSecondary" Color="#8899aa" />
    <SolidColorBrush x:Key="LaunchGreen" Color="#00b894" />
    <SolidColorBrush x:Key="WarningOrange" Color="#fdcb6e" />

    <!-- Dark scrollbar thumb -->
    <Style x:Key="DarkScrollThumb" TargetType="Thumb">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="thumbBorder" Background="#44ffffff" CornerRadius="3" Margin="1" />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="thumbBorder" Property="Background" Value="#66ffffff" />
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="thumbBorder" Property="Background" Value="#88ffffff" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Dark vertical scrollbar -->
    <Style TargetType="ScrollBar">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Width" Value="8" />
      <Setter Property="MinWidth" Value="8" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Background="Transparent">
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.Thumb>
                  <Thumb Style="{StaticResource DarkScrollThumb}" />
                </Track.Thumb>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Width" Value="Auto" />
          <Setter Property="Height" Value="8" />
          <Setter Property="MinHeight" Value="8" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- Profile button style -->
    <Style x:Key="ProfileBtn" TargetType="Button">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="2" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="bd"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="8"
              Padding="{TemplateBinding Padding}"
            >
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.7" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Action button style -->
    <Style x:Key="ActionBtn" TargetType="Button">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border
              x:Name="bd"
              Background="{TemplateBinding Background}"
              CornerRadius="6"
              Padding="{TemplateBinding Padding}"
            >
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.85" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="bd" Property="Opacity" Value="0.7" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Link button style -->
    <Style x:Key="LinkBtn" TargetType="Button">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <TextBlock
              x:Name="tb"
              Text="{TemplateBinding Content}"
              Foreground="{TemplateBinding Foreground}"
              TextDecorations="Underline"
              Padding="{TemplateBinding Padding}"
            />
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter
                  TargetName="tb"
                  Property="Foreground"
                  Value="{StaticResource TextPrimary}"
                />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <!-- 0: Title -->
      <RowDefinition Height="Auto" />
      <!-- 1: Active profile -->
      <RowDefinition Height="Auto" />
      <!-- 2: Profile buttons -->
      <RowDefinition Height="Auto" />
      <!-- 3: Action buttons -->
      <RowDefinition Height="Auto" />
      <!-- 4: Save profile -->
      <RowDefinition Height="*" />
      <!-- 5: Log -->
      <RowDefinition Height="Auto" />
      <!-- 6: Status bar -->
      <RowDefinition Height="Auto" />
      <!-- 7: Settings link -->
    </Grid.RowDefinitions>

    <!-- Title -->
    <TextBlock
      Grid.Row="0"
      Text="HearthSwing"
      FontSize="22"
      FontWeight="Bold"
      Foreground="{StaticResource TextPrimary}"
      HorizontalAlignment="Center"
      Margin="0,0,0,4"
    />

    <!-- Current profile indicator -->
    <Border
      Grid.Row="1"
      Background="{StaticResource PanelBg}"
      CornerRadius="8"
      Padding="12,8"
      Margin="0,4"
    >
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <TextBlock
          Text="Active Profile: "
          FontSize="14"
          Foreground="{StaticResource TextSecondary}"
          VerticalAlignment="Center"
        />
        <TextBlock
          x:Name="ProfileIndicator"
          Text="{Binding CurrentProfileName}"
          FontSize="18"
          FontWeight="Bold"
          Foreground="{StaticResource DonkyBrush}"
          VerticalAlignment="Center"
        />
      </StackPanel>
    </Border>

    <!-- Profile switch buttons (dynamic) -->
    <ItemsControl
      x:Name="ProfileButtons"
      Grid.Row="2"
      ItemsSource="{Binding Profiles}"
      Margin="0,8"
    >
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <WrapPanel HorizontalAlignment="Center" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Button
            Content="{Binding DisplayName}"
            Style="{StaticResource ProfileBtn}"
            Background="{StaticResource CardBg}"
            BorderBrush="{StaticResource DonkyBrush}"
            Command="{Binding DataContext.SwitchProfileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
            CommandParameter="{Binding Id}"
            MinWidth="120"
          />
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Action buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4">
      <Button
        Content="&#x1F680; Launch WoW"
        Style="{StaticResource ActionBtn}"
        Background="{StaticResource LaunchGreen}"
        Command="{Binding LaunchWowCommand}"
        MinWidth="140"
      />
      <Button
        Content="&#x1F504; Restore"
        Style="{StaticResource ActionBtn}"
        Background="#6c5ce7"
        Command="{Binding ForceRestoreCommand}"
        Visibility="{Binding IsWowRunning, Converter={StaticResource BoolToVis}}"
        ToolTip="Force-restore cache files from backup + touch timestamps. Then type /reload in WoW."
        MinWidth="100"
      />
      <Button
        Content="&#x1F513; Unlock"
        Style="{StaticResource ActionBtn}"
        Background="{StaticResource WarningOrange}"
        Foreground="#2d3436"
        Command="{Binding ForceUnlockCommand}"
        Visibility="{Binding IsCacheLocked, Converter={StaticResource BoolToVis}}"
        MinWidth="100"
      />
    </StackPanel>

    <!-- Save current WTF as profile -->
    <Border
      Grid.Row="4"
      Background="{StaticResource PanelBg}"
      CornerRadius="6"
      Padding="8,6"
      Margin="0,4,0,0"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
          Text="Save WTF as:"
          Foreground="{StaticResource TextSecondary}"
          FontSize="12"
          VerticalAlignment="Center"
          Margin="0,0,6,0"
        />
        <TextBox
          Grid.Column="1"
          Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
          FontSize="12"
          Padding="4,3"
          VerticalAlignment="Center"
        />
        <Button
          Grid.Column="2"
          Content="Save"
          Style="{StaticResource ActionBtn}"
          Background="{StaticResource DonkyBrush}"
          Command="{Binding SaveCurrentProfileCommand}"
          Padding="12,4"
          Margin="4,0,0,0"
          MinWidth="60"
        />
      </Grid>
    </Border>

    <!-- Log area -->
    <Border
      Grid.Row="5"
      Background="{StaticResource PanelBg}"
      CornerRadius="6"
      Margin="0,8"
      Padding="8"
    >
      <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
        <TextBlock
          Text="{Binding LogText}"
          Foreground="{StaticResource TextSecondary}"
          FontFamily="Consolas"
          FontSize="11"
          TextWrapping="Wrap"
        />
      </ScrollViewer>
    </Border>

    <!-- Status bar -->
    <Border
      Grid.Row="6"
      Background="{StaticResource CardBg}"
      CornerRadius="4"
      Padding="8,4"
      Margin="0,2"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
          Grid.Column="0"
          Text="{Binding StatusText}"
          Foreground="{StaticResource TextSecondary}"
          FontSize="11"
          VerticalAlignment="Center"
        />
        <TextBlock
          Grid.Column="1"
          Text="&#x1F512;"
          FontSize="14"
          VerticalAlignment="Center"
          Margin="6,0"
          Visibility="{Binding IsCacheLocked, Converter={StaticResource BoolToVis}}"
          ToolTip="Cache files are locked (read-only)"
        />
        <TextBlock
          Grid.Column="2"
          Text="&#x1F7E2;"
          FontSize="14"
          VerticalAlignment="Center"
          Margin="6,0"
          Visibility="{Binding IsWowRunning, Converter={StaticResource BoolToVis}}"
          ToolTip="WoW is running"
        />
      </Grid>
    </Border>

    <!-- Footer links -->
    <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
      <Button
        Content="How to use"
        Style="{StaticResource LinkBtn}"
        Command="{Binding ToggleHowToUseCommand}"
        Margin="0,0,8,0"
      />
      <Button
        Content="About"
        Style="{StaticResource LinkBtn}"
        Command="{Binding ToggleAboutCommand}"
        Margin="0,0,8,0"
      />
      <Button
        Content="Settings"
        Style="{StaticResource LinkBtn}"
        Command="{Binding ToggleSettingsCommand}"
      />
    </StackPanel>

    <!-- Settings panel (overlay) -->
    <Border
      Grid.Row="0"
      Grid.RowSpan="8"
      Background="#ee1a1a2e"
      CornerRadius="8"
      Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVis}}"
      Padding="20"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      MinWidth="340"
    >
      <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16">
        <StackPanel>
          <TextBlock
            Text="Settings"
            FontSize="16"
            FontWeight="Bold"
            Foreground="{StaticResource TextPrimary}"
            Margin="0,0,0,12"
          />

          <TextBlock
            Text="Game Path:"
            Foreground="{StaticResource TextSecondary}"
            FontSize="12"
            Margin="0,0,0,2"
          />
          <TextBox
            Text="{Binding GamePath, UpdateSourceTrigger=PropertyChanged}"
            FontSize="12"
            Padding="6,4"
            Margin="0,0,0,8"
          />

          <TextBlock
            Text="Profiles Path:"
            Foreground="{StaticResource TextSecondary}"
            FontSize="12"
            Margin="0,0,0,2"
          />
          <TextBox
            Text="{Binding ProfilesPath, UpdateSourceTrigger=PropertyChanged}"
            FontSize="12"
            Padding="6,4"
            Margin="0,0,0,8"
          />

          <TextBlock
            Text="Unlock Delay (seconds):"
            Foreground="{StaticResource TextSecondary}"
            FontSize="12"
            Margin="0,0,0,2"
          />
          <TextBox
            Text="{Binding UnlockDelay, UpdateSourceTrigger=PropertyChanged}"
            FontSize="12"
            Padding="6,4"
            Width="80"
            HorizontalAlignment="Left"
            Margin="0,0,0,12"
          />

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button
              Content="Save"
              Style="{StaticResource ActionBtn}"
              Background="{StaticResource LaunchGreen}"
              Command="{Binding SaveSettingsCommand}"
              MinWidth="80"
            />
            <Button
              Content="Cancel"
              Style="{StaticResource ActionBtn}"
              Background="{StaticResource TextSecondary}"
              Command="{Binding ToggleSettingsCommand}"
              MinWidth="80"
            />
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
    <!-- About overlay -->
    <Border
      Grid.Row="0"
      Grid.RowSpan="8"
      Background="#ee1a1a2e"
      CornerRadius="8"
      Visibility="{Binding IsAboutVisible, Converter={StaticResource BoolToVis}}"
      Padding="20"
      VerticalAlignment="Center"
      HorizontalAlignment="Center"
      MinWidth="300"
    >
      <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16">
        <StackPanel>
          <TextBlock
            Text="About HearthSwing"
            FontSize="16"
            FontWeight="Bold"
            Foreground="{StaticResource TextPrimary}"
            Margin="0,0,0,12"
          />
          <TextBlock
            Foreground="{StaticResource TextSecondary}"
            FontSize="12"
            TextWrapping="Wrap"
            Margin="0,0,0,4"
          >
            <Run Text="Version: " />
            <Run Text="{Binding AppVersion, Mode=OneTime}" FontWeight="SemiBold" />
          </TextBlock>
          <TextBlock
            Text="WoW Classic Anniversary profile switcher"
            Foreground="{StaticResource TextSecondary}"
            FontSize="12"
            TextWrapping="Wrap"
            Margin="0,0,0,4"
          />
          <TextBlock
            Foreground="{StaticResource TextSecondary}"
            FontSize="12"
            TextWrapping="Wrap"
            Margin="0,0,0,12"
          >
            <Run Text="Author: " />
            <Run Text="CoffeeNova" FontWeight="SemiBold" />
          </TextBlock>
          <Button
            Content="Close"
            Style="{StaticResource ActionBtn}"
            Background="{StaticResource TextSecondary}"
            Command="{Binding ToggleAboutCommand}"
            HorizontalAlignment="Right"
            MinWidth="80"
          />
        </StackPanel>
      </Border>
    </Border>

    <!-- How to use overlay -->
    <Border
      Grid.Row="0"
      Grid.RowSpan="8"
      Background="#ee1a1a2e"
      CornerRadius="8"
      Visibility="{Binding IsHowToUseVisible, Converter={StaticResource BoolToVis}}"
      Padding="20"
      VerticalAlignment="Stretch"
      HorizontalAlignment="Stretch"
    >
      <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock
            Grid.Row="0"
            Text="How to Use"
            FontSize="16"
            FontWeight="Bold"
            Foreground="{StaticResource TextPrimary}"
            Margin="0,0,0,12"
          />
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <TextBlock
              Foreground="{StaticResource TextSecondary}"
              FontSize="12"
              TextWrapping="Wrap"
              LineHeight="20"
              xml:space="preserve"
            >
              <Run
                FontWeight="SemiBold"
                Text="1. Setup"
              />
Place HearthSwing.exe anywhere you like. Open Settings and set the Game Path (folder with WowClassic.exe) and Profiles Path (where profile snapshots are stored).

<Run
                FontWeight="SemiBold"
                Text="2. Save a profile"
              />
Enter a name in the "Save WTF as" field and click Save. This copies your current WTF folder as a named profile snapshot.

<Run
                FontWeight="SemiBold"
                Text="3. Switch profiles"
              />
Click a profile button to swap the active WTF folder. The previous profile is parked automatically. After switching, launch WoW and click Restore, then type /reload in the game to apply the restored cache files.

<Run
                FontWeight="SemiBold"
                Text="4. Launch WoW"
              />
Click "Launch WoW" to start the game with cache protection enabled. Cache files are locked read-only and restored from backup to prevent server sync from overwriting your local settings.

<Run
                FontWeight="SemiBold"
                Text="5. Cache protection"
              />
After launch, cache files stay locked for the configured delay (default 120s). Use "Unlock" to release early or "Restore" to force-restore from backup while WoW is running (type /reload after).

<Run
                FontWeight="SemiBold"
                Text="Note:"
              />
HearthSwing transfers macros, keybindings, edit mode layout, and addon settings. Action bars are NOT transferred. Use the ActionBarSaver addon (for TBC Anniversary: ActionBarSaver Reloaded) to save/restore action bars separately.</TextBlock
            >
          </ScrollViewer>
          <Button
            Grid.Row="2"
            Content="Close"
            Style="{StaticResource ActionBtn}"
            Background="{StaticResource TextSecondary}"
            Command="{Binding ToggleHowToUseCommand}"
            HorizontalAlignment="Right"
            MinWidth="80"
          />
        </Grid>
      </Border>
    </Border>
  </Grid>
</Window>
